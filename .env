# =====================
# SERVER
# =====================
SERVER_PORT=8080

# =====================
# DATABASE
# =====================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=bank_transfers
DB_SSLMODE=disable

# =====================
# POOL SETTINGS (опционально, но полезно)
# =====================
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m

# =====================
# LOGGING
# =====================
LOG_LEVEL=debug